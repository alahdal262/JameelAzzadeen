# البريد الإلكتروني لحساب المدير الوحيد
ADMIN_EMAIL=
# كلمة مرور حساب المدير (تُخزَّن مشفّرة بـ bcrypt)
ADMIN_PASSWORD=
# مفتاح Gemini API المستخدم أثناء بناء الواجهة (vite build)
GEMINI_API_KEY=
